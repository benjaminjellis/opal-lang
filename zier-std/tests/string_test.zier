(use std/string)
(use std/result [bind])
(use std/testing [assert_eq assert assert_ne])

(test
  "string/length"
  (let? [_ (assert_eq (string/length "hello") 5)]
    (assert_eq (string/length "") 0)))

(test
  "string/is_empty"
  (let? [_ (assert (string/is_empty ""))]
    (assert_ne (string/is_empty "hi") True)))

(test "string/trim" (assert_eq (string/trim "  hello  ") "hello"))

(test "string/uppercase" (assert_eq (string/uppercase "hello") "HELLO"))

(test "string/lowercase" (assert_eq (string/lowercase "HELLO") "hello"))

(test "string/casefold" (assert_eq (string/casefold "HELLO") "hello"))

(test
  "string/concat"
  (assert_eq (string/concat "hello" " world") "hello world"))

(test
  "string/contains"
  (let? [_ (assert (string/contains "hello world" "world"))]
    (assert_ne (string/contains "hello world" "xyz") True)))

(test "string/split" (assert_eq (string/split "a,b,c" ",") ["a" "b" "c"]))
